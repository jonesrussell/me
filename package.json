{
	"name": "me",
	"version": "0.1.0",
	"homepage": "https://jonesrussell.github.io/me/",
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development vite dev --host",
		"build": "NODE_ENV=production vite build",
		"preview": "NODE_ENV=production vite preview --host",
		"test": "NODE_ENV=development npm run test:integration && NODE_ENV=development npm run test:unit",
		"check": "NODE_ENV=development svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "NODE_ENV=development svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "NODE_ENV=development prettier --check . && NODE_ENV=development eslint .",
		"format": "NODE_ENV=development prettier --write .",
		"test:integration": "NODE_ENV=development playwright test",
		"test:unit": "NODE_ENV=development vitest --run",
		"test:coverage": "NODE_ENV=development vitest run --coverage",
		"test:watch": "vitest",
		"test:ui": "vitest --ui",
		"test:debug": "vitest --inspect-brk --no-threads",
		"workflow": "act -P ubuntu-latest=mcr.microsoft.com/playwright:v1.42.1-jammy",
		"workflow:list": "act -l",
		"workflow:test": "act -j test -P ubuntu-latest=mcr.microsoft.com/playwright:v1.42.1-jammy",
		"workflow:build": "act -j build -P ubuntu-latest=mcr.microsoft.com/playwright:v1.42.1-jammy",
		"workflow:deploy": "act -j deploy -P ubuntu-latest=mcr.microsoft.com/playwright:v1.42.1-jammy",
		"workflow:full": "act -P ubuntu-latest=mcr.microsoft.com/playwright:v1.42.1-jammy --reuse"
	},
	"devDependencies": {
		"@fontsource/fira-mono": "^5.1.0",
		"@playwright/test": "^1.45.3",
		"@sveltejs/adapter-auto": "^3.0.0",
		"@sveltejs/adapter-static": "^3.0.6",
		"@sveltejs/enhanced-img": "^0.4.4",
		"@sveltejs/kit": "^2.9.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@testing-library/dom": "^9.3.4",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/svelte": "^5.2.6",
		"@testing-library/user-event": "^14.5.2",
		"@types/node": "^22.10.2",
		"@vitest/coverage-v8": "^2.1.8",
		"@vitest/ui": "^2.1.8",
		"eslint": "^9.7.0",
		"eslint-config-prettier": "^9.1.0",
		"eslint-plugin-svelte": "^2.36.0",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.0.0",
		"vite": "^6.0.0",
		"vitest": "^2.0.4"
	}
}
